FROM python:3.11-slim

RUN apt-get update && \
    apt-get install -y --no-install-recommends curl openjdk-21-jre-headless procps && \
    rm -rf /var/lib/apt/lists/*

COPY requirements.txt /tmp/requirements.txt
RUN pip install --no-cache-dir -r /tmp/requirements.txt

RUN curl -fsSL -o /usr/local/lib/python3.11/site-packages/pyspark/jars/spark-sql-kafka-0-10_2.12-3.5.1.jar \
      https://repo1.maven.org/maven2/org/apache/spark/spark-sql-kafka-0-10_2.12/3.5.1/spark-sql-kafka-0-10_2.12-3.5.1.jar && \
    curl -fsSL -o /usr/local/lib/python3.11/site-packages/pyspark/jars/spark-token-provider-kafka-0-10_2.12-3.5.1.jar \
      https://repo1.maven.org/maven2/org/apache/spark/spark-token-provider-kafka-0-10_2.12/3.5.1/spark-token-provider-kafka-0-10_2.12-3.5.1.jar && \
    curl -fsSL -o /usr/local/lib/python3.11/site-packages/pyspark/jars/kafka-clients-3.4.1.jar \
      https://repo1.maven.org/maven2/org/apache/kafka/kafka-clients/3.4.1/kafka-clients-3.4.1.jar && \
    curl -fsSL -o /usr/local/lib/python3.11/site-packages/pyspark/jars/commons-pool2-2.11.1.jar \
      https://repo1.maven.org/maven2/org/apache/commons/commons-pool2/2.11.1/commons-pool2-2.11.1.jar && \
    curl -fsSL -o /usr/local/lib/python3.11/site-packages/pyspark/jars/elasticsearch-spark-30_2.12-8.10.0.jar \
      https://repo1.maven.org/maven2/org/elasticsearch/elasticsearch-spark-30_2.12/8.10.0/elasticsearch-spark-30_2.12-8.10.0.jar && \
    curl -fsSL -o /usr/local/lib/python3.11/site-packages/pyspark/jars/hadoop-aws-3.3.4.jar \
      https://repo1.maven.org/maven2/org/apache/hadoop/hadoop-aws/3.3.4/hadoop-aws-3.3.4.jar && \
    curl -fsSL -o /usr/local/lib/python3.11/site-packages/pyspark/jars/aws-java-sdk-bundle-1.12.262.jar \
      https://repo1.maven.org/maven2/com/amazonaws/aws-java-sdk-bundle/1.12.262/aws-java-sdk-bundle-1.12.262.jar && \
    curl -fsSL -o /usr/local/lib/python3.11/site-packages/pyspark/jars/wildfly-openssl-1.0.7.Final.jar \
      https://repo1.maven.org/maven2/org/wildfly/openssl/wildfly-openssl/1.0.7.Final/wildfly-openssl-1.0.7.Final.jar

WORKDIR /opt/social-media-analytics
COPY . .

ENV PYTHONPATH=/opt/social-media-analytics

CMD ["/bin/bash", "-lc", "sleep infinity"]
